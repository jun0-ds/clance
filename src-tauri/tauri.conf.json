{
  "$schema": "https://raw.githubusercontent.com/nicoco007/tauri/dev-2/crates/tauri-utils/schema.json",
  "productName": "Clance",
  "version": "0.1.0",
  "identifier": "com.clance.widget",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clance",
        "width": 300,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
